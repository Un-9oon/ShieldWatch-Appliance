# ShieldWatch Appliance Environment Configuration
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Admin Dashboard Password (REQUIRED)
SW_ADMIN_PASS=

# Internal API Token for Sensor communication (REQUIRED)
SW_API_TOKEN=

# Session Encryption Secret (REQUIRED)
SW_SESSION_SECRET=

# Port to listen on (Default: 3002)
SW_PORT=3002

# Set to 'production' to enable Secure HTTPS-only cookies and HSTS
# NOTE: If NODE_ENV=production, the dashboard will only work over HTTPS.
NODE_ENV=development

# ⚠️ WARNING: The collector will refuse to start if secrets are missing 
# or still set to default values.
